{
  "entities": {
    "Request": {
      "title": "Emergency Request",
      "description": "A request for help from a user in an emergency situation.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The UID of the user who made the request." },
        "userName": { "type": "string", "description": "The name of the user." },
        "userPhoto": { "type": "string", "description": "The photo URL of the user." },
        "message": { "type": "string", "description": "The help message provided by the user." },
        "imageUrl": { "type": "string", "description": "Optional image URL uploaded by the user." },
        "location": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          },
          "required": ["lat", "lng"]
        },
        "category": { "type": "string", "enum": ["Food", "Medical", "Rescue", "Other"], "description": "Categorized by Gemini AI." },
        "urgency": { "type": "number", "description": "Urgency score (1-10) assigned by Gemini AI." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp of the request." }
      },
      "required": ["userId", "message", "location", "category", "urgency", "createdAt"]
    }
  },
  "firestore": {
    "/requests/{requestId}": {
      "schema": "Request",
      "description": "Collection of emergency requests."
    }
  }
}
